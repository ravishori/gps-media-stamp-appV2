@page
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>System Error</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #0f172a;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: white;
        }

        .container {
            background: #1e293b;
            padding: 50px;
            border-radius: 16px;
            width: 500px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        }

        h1 {
            margin-bottom: 20px;
            font-size: 26px;
        }

        p {
            color: #cbd5e1;
            font-size: 16px;
        }

        .btn {
            margin-top: 30px;
            padding: 12px 25px;
            background: #2563eb;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            display: inline-block;
        }

        .btn:hover {
            background: #1d4ed8;
        }

        .small {
            margin-top: 20px;
            font-size: 13px;
            color: #94a3b8;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>⚠ Something went wrong</h1>
        <p>
            An unexpected error occurred while processing your request.
        </p>

        <a href="/" class="btn">Go Back Home</a>

        <div class="small">
            If the issue persists, please contact support.
        </div>
    </div>
</body>
</html>